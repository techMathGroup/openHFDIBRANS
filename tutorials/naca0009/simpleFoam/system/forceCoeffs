FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      forceCoeffs;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

forceCoeffs
{
    type            forceCoeffs;
    libs            ("libforces.so");

    patches         ("walls");

    rho             rhoInf;
    rhoInf          1000.0;

    CofR            (0 0 0); // center of rotation (used for moments)
    dragDir         (1 0 0); // direction of flow
    liftDir         (0 1 0); // direction of lift
    pitchAxis       (0 1 0); // axis for pitching moment

    magUInf         13.187;    // freestream velocity in m/s
    lRef            1.0;   // reference length (length of the body)
    Aref            0.004;   // frontal projected area in m^2
}
