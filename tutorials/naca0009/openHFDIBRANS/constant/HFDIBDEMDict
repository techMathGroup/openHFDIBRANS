FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      HFDIBDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

surfaceThreshold    1e-4;
sdBasedLambda       false;
stlName             naca;
interfaceSpan       1.0;
saveIntInfo         false;
surfAreaType        cutEdges;

wallFunctions
{
    nut		nutkWallFunction;
    k       kLowReWallFunction;
    omega   omegaWallFunction;
    epsilon epsilonWallFunction;
}

forceCoeffs 
{
    rhoInf      1000.0;
    dragDir     (1 0 0);
    liftDir     (0 1 0);
    magUInf     13.187;
    ARef        0.004;
}

